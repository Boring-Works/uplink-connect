{
	"name": "uplink-connect",
	"private": true,
	"version": "0.1.0",
	"packageManager": "pnpm@10.6.1",
	"scripts": {
		"typecheck": "pnpm -r typecheck",
		"build": "pnpm -r build",
		"dev:edge": "pnpm --filter @uplink/edge dev",
		"dev:core": "pnpm --filter @uplink/core dev",
		"dev:browser": "pnpm --filter @uplink/browser dev",
		"dev:ops": "pnpm --filter @uplink/ops dev",
		"test": "pnpm --filter @uplink/core test",
		"test:watch": "pnpm --filter @uplink/core test:watch"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260403.0",
		"typescript": "^5.8.3",
		"wrangler": "^4.38.0"
	}
}
