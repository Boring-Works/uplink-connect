{
	"$schema": "../../node_modules/wrangler/config-schema.json",
	"name": "uplink-ops",
	"main": "src/index.ts",
	"compatibility_date": "2026-04-12",
	"compatibility_flags": ["nodejs_compat"],
	"workers_dev": false,
	"observability": {
		"enabled": true,
		"logs": {
			"head_sampling_rate": 1
		}
	},
	"services": [
		{
			"binding": "UPLINK_CORE",
			"service": "uplink-core"
		}
	]
}
